# ── Application ────────────────────────────────────────────────────────────
APP_NAME="Multiagents API"
DEBUG=false
API_V1_PREFIX=/api/v1

# ── Couchbase ────────────────────────────────────────────────────────────────
COUCHBASE_CLOUD_ENDPOINT=cb.localhost.couchbase.com
COUCHBASE_USER=Administrator
COUCHBASE_PASSWORD=password
COUCHBASE_BUCKET=travel-sample
COUCHBASE_SCOPE=inventory
COUCHBASE_COLLECTION=airline

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Use "localhost:9092" when running the app outside Docker,
# or "broker:29092" when running inside the same Docker network.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PROMPT=user-prompts
KAFKA_PRODUCER_CLIENT_ID=multiagents-producer

# ── Schema Registry ───────────────────────────────────────────────────────────
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── Keycloak ──────────────────────────────────────────────────────────────────
# Keycloak is exposed on port 8092 (maps to container port 8080).
KEYCLOAK_URL=http://localhost:8092
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=multiagents-client
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
KEYCLOAK_ALGORITHMS=["RS256"]
