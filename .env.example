# ── Application ────────────────────────────────────────────────────────────
APP_NAME="Multiagents API"
DEBUG=false
API_V1_PREFIX=/v1
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Geocoding/routing
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT="RoutingProblem/1.0 (your-email@example.com)"
NOMINATIM_EMAIL=your-email@example.com
OSRM_BASE_URL=https://router.project-osrm.org

# ── Couchbase ────────────────────────────────────────────────────────────────
COUCHBASE_CONNECT_ENDPOINT=cb.localhost.couchbase.com
COUCHBASE_USERNAME=Administrator
COUCHBASE_PASSWORD=password
COUCHBASE_BUCKET=travel-sample
COUCHBASE_SCOPE=inventory
COUCHBASE_COLLECTION=airline

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Use "localhost:9092" when running the app outside Docker,
# or "broker:29092" when running inside the same Docker network.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PROMPT=user-prompts
KAFKA_TOPIC_ORDER_EVENTS=order-events
KAFKA_PRODUCER_CLIENT_ID=multiagents-producer

# ── Schema Registry ───────────────────────────────────────────────────────────
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── Keycloak ──────────────────────────────────────────────────────────────────
# Keycloak is exposed on port 8092 (maps to container port 8080).
KEYCLOAK_URL=http://localhost:8092
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=multiagents-client
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
KEYCLOAK_ALGORITHMS=["RS256"]

# Frontend build-time variables. Rebuild the frontend image after changing these.
VITE_HOST_BACKEND=
VITE_KEYCLOAK_URL=http://localhost:8092/auth
VITE_KEYCLOAK_REALM=master
VITE_KEYCLOAK_CLIENT_ID=multiagents-client
